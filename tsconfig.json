{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2015",
        "strictNullChecks": true,
        "esModuleInterop": true,
        "jsx": "react",
        "lib": [
            "es2021",
            "dom"
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "typeRoots": [
            "node_modules/@types",
            "./types"
        ],
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "landing/*": [
                "./landing/*"
            ],
            "docs/*": [
                "./docs/*"
            ],
            "package/*": [
                "./package/*"
            ],
            "server/*": [
                "./server/*"
            ],
        }
    },
    "exclude": [
        "**/*.css"
    ]
}
